{
  "_comment": "This is an example configuration. Copy this to ~/.cursor/mcp.json and update the path and credentials.",
  "mcpServers": {
    "datadog": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/techskies11/datadog-mcp",
        "--with",
        "fastmcp",
        "python",
        "-m",
        "datadog_mcp.server"
      ],
      "env": {
        "DD_API_KEY": "your-datadog-api-key-here",
        "DD_APP_KEY": "your-datadog-application-key-here",
        "DD_SITE": "datadoghq.com"
      }
    }
  }
}
