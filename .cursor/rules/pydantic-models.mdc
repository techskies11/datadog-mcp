```

## Generic Models with TypeVar

```python
from pydantic import BaseModel
from typing import TypeVar, Generic

T = TypeVar('T')

class ApiResponse(BaseModel, Generic[T]):
    """Generic API response."""
    success: bool
    data: T
    error: str | None = None

# ✅ Use with specific types
class UserData(BaseModel):
    id: str
    name: str

def get_user(user_id: str) -> ApiResponse[UserData]:
    return ApiResponse(
        success=True,
        data=UserData(id=user_id, name="John")
    )
```

## FastMCP Integration

FastMCP automatically handles Pydantic models:

```python
from fastmcp import FastMCP
from pydantic import BaseModel

mcp = FastMCP("My Server")

class SearchRequest(BaseModel):
    """Search request parameters."""
    query: str
    limit: int = 10

class SearchResponse(BaseModel):
    """Search results."""
    results: list[str]
    count: int

# ✅ FastMCP auto-generates JSON schema from Pydantic
@mcp.tool()
def search(request: SearchRequest) -> SearchResponse:
    """FastMCP validates input and output automatically."""
    results = perform_search(request.query, request.limit)
    return SearchResponse(results=results, count=len(results))
```

## Error Handling

```python
from pydantic import BaseModel, ValidationError

class SearchResponse(BaseModel):
    success: bool
    logs: list[LogEntry]
    count: int

def search_logs(query: str) -> SearchResponse:
    try:
        # ... get logs from API
        return SearchResponse(
            success=True,
            logs=logs,
            count=len(logs)
        )
    except ValidationError as e:
        # Pydantic validation failed - this is a code bug!
        raise ValueError(f"Response validation failed: {e}")
    except Exception as e:
        # API error - return error response
        return SearchResponse(
            success=False,
            logs=[],
            count=0,
            error=str(e)
        )
```

