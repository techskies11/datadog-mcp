class CreateDashboardRequest(BaseModel):
    """Request to create dashboard."""
    title: str = Field(..., description="Dashboard title", examples=["API Performance"])
    layout_type: Literal["ordered", "free"] = Field(..., description="Layout type")
    widgets: list[dict[str, object]] = Field(default_factory=list, description="Widget definitions")

# ✅ FastMCP uses this schema to validate calls
@mcp.tool()
def create_dashboard(request: CreateDashboardRequest) -> DashboardResponse:
    """Create dashboard - schema auto-generated from Pydantic."""
