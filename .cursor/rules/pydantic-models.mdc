# Pydantic for FastMCP

Use Pydantic models for ALL tool inputs and outputs. Pydantic provides runtime validation, better IDE support, and integrates perfectly with FastMCP.

## Why Pydantic Over TypedDict

```python
# ❌ BAD - TypedDict has no runtime validation
from typing import TypedDict

class SearchResponse(TypedDict):
    success: bool
    count: int

def search(query: str) -> SearchResponse:
    return {"success": True}  # Missing 'count', no error at runtime!

# ✅ GOOD - Pydantic validates at runtime
from pydantic import BaseModel, Field

class SearchResponse(BaseModel):
    success: bool
    count: int

def search(query: str) -> SearchResponse:
    return SearchResponse(success=True)  # ValidationError: missing 'count'
```

## Basic Pydantic Model Pattern

```python
from pydantic import BaseModel, Field
from typing import Literal

# ✅ Define response models
class LogEntry(BaseModel):
    """Individual log entry."""
    id: str
    message: str | None = None
    timestamp: str | None = None
    status: Literal["info", "warning", "error", "debug"] | None = None
    service: str | None = None
    tags: list[str] = Field(default_factory=list)

class SearchLogsResponse(BaseModel):
    """Response from search_logs tool."""
    success: bool
    logs: list[LogEntry]
    count: int
    next_cursor: str | None = None
    has_more: bool = False

# ✅ Use in FastMCP tool
@mcp.tool()
def search_logs(
    query: str,
    from_time: str,
    to_time: str
) -> SearchLogsResponse:
    """Search logs with Pydantic validation."""
    # ... implementation
    return SearchLogsResponse(
        success=True,
        logs=[...],
        count=10
    )
```

## Field Validation

Use Pydantic's `Field` for validation and metadata:

```python
from pydantic import BaseModel, Field, field_validator

class CreateMonitorRequest(BaseModel):
    """Request to create a monitor."""
    name: str = Field(..., min_length=1, max_length=200, description="Monitor name")
    query: str = Field(..., min_length=1, description="Alert query")
    message: str = Field(..., description="Notification message")
    priority: int = Field(default=3, ge=1, le=5, description="Priority 1-5")
    tags: list[str] = Field(default_factory=list, max_length=50)

    @field_validator('query')
    @classmethod
    def validate_query(cls, v: str) -> str:
        if not v.strip():
            raise ValueError("Query cannot be empty")
        return v.strip()

# ✅ Use in tool
@mcp.tool()
def create_monitor(request: CreateMonitorRequest) -> MonitorResponse:
    """Create monitor with validated input."""
    # Pydantic has already validated all fields!
    auth = get_auth_instance()
    return _create_monitor(request, auth=auth)
```

## Config Class

Configure Pydantic behavior:

```python
from pydantic import BaseModel, ConfigDict

class LogEntry(BaseModel):
    """Log entry with strict configuration."""
    model_config = ConfigDict(
        strict=True,           # Strict type checking
        frozen=False,          # Mutable by default
        extra='forbid',        # Forbid extra fields
        validate_assignment=True,  # Validate on assignment
        str_strip_whitespace=True,  # Auto-strip strings
    )

    id: str
    message: str | None = None
    timestamp: str | None = None
```

## Common Response Patterns

### Success/Error Response

```python
from pydantic import BaseModel

class BaseResponse(BaseModel):
    """Base response with success flag."""
    success: bool

class ErrorResponse(BaseResponse):
    """Error response."""
    success: bool = False
    error: str

class DataResponse(BaseResponse):
    """Successful response with data."""
    success: bool = True
    count: int

class SearchLogsResponse(DataResponse):
    """Search logs response."""
    logs: list[LogEntry]
    next_cursor: str | None = None
    has_more: bool = False
```

### Paginated Response

```python
from pydantic import BaseModel, Field

class PaginatedResponse[T](BaseModel):
    """Generic paginated response."""
    success: bool = True
    items: list[T]
    count: int = Field(ge=0)
    page_size: int = Field(ge=1, le=50)
    next_cursor: str | None = None
    has_more: bool = False

# ✅ Use with specific type
class SearchLogsResponse(PaginatedResponse[LogEntry]):
    """Paginated log search results."""
    pass
```

## Converting API Responses

Use Pydantic to parse external API responses:

```python
from pydantic import BaseModel
from datadog_api_client.v2.api.logs_api import LogsApi

class LogEntry(BaseModel):
    """Validated log entry."""
    id: str
    message: str | None = None
    timestamp: str | None = None

def search_logs(query: str, auth: DatadogAuth) -> SearchLogsResponse:
    """Search logs with Pydantic validation."""
    api = LogsApi(auth.api_client)
    response = api.list_logs(...)

    # ✅ Parse and validate API response
    logs: list[LogEntry] = []
    if hasattr(response, 'data') and response.data:
        for log in response.data:
            # Pydantic validates each entry
            logs.append(LogEntry(
                id=log.id if hasattr(log, 'id') else "",
                message=log.attributes.message if hasattr(log.attributes, 'message') else None,
                timestamp=log.attributes.timestamp.isoformat() if hasattr(log.attributes, 'timestamp') else None
            ))

    return SearchLogsResponse(
        success=True,
        logs=logs,
        count=len(logs)
    )
```

## Alias and Serialization

Handle field name differences:

```python
from pydantic import BaseModel, Field

class LogEntry(BaseModel):
    """Log entry with field aliases."""
    id: str
    message: str | None = None
    # Map @timestamp from Datadog to timestamp field
    timestamp: str | None = Field(None, alias="@timestamp")
    # Map @session_id to session_id
    session_id: str | None = Field(None, alias="@session_id")

# ✅ Parse with aliases
log = LogEntry.model_validate({
    "id": "abc123",
    "@timestamp": "2024-01-28T10:00:00Z",
    "@session_id": "sess_xyz"
})

# ✅ Serialize with aliases
log.model_dump(by_alias=True)
# {"id": "abc123", "@timestamp": "2024-01-28T10:00:00Z", "@session_id": "sess_xyz"}
```

